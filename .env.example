# ─────────────────────────────────────────────────
#  roomi-backend — environment variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# App
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── AI / Generative ───────────────────────────────
# Replicate (Stable Diffusion + ControlNet)
# Get your key at https://replicate.com/account/api-tokens
# Leave empty to use mock responses
REPLICATE_API_TOKEN=

# OpenAI (AI Chat assistant)
# Get your key at https://platform.openai.com/api-keys
# Leave empty to use mock responses
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Replicate model IDs ───────────────────────────
# Interior design model (ControlNet-based)
REPLICATE_INTERIOR_MODEL=adirik/interior-design:76604baddc85b1b4616e1c6475eca080da339c8875bd4996705440484a6eac38
