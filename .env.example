# ── Server ────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Public URL the browser uses to load generated images.
# Locally: http://localhost:8000
# Docker:  http://localhost:8000  (same — browser talks to host port)
PUBLIC_URL=http://localhost:8000

# ── CORS ──────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── AI keys (leave empty = mock mode) ─────────────

# Stable Diffusion + ControlNet via Replicate (cloud)
REPLICATE_API_TOKEN=r8_...

# Llama via Groq (free tier at console.groq.com)
GROQ_API_KEY=gsk_...

# ChatGPT fallback (optional)
OPENAI_API_KEY=sk-...

# ── Local SD (RTX 3050 4GB) ───────────────────────
# Set to true to use local GPU instead of Replicate
LOCAL_SD=false
# LOCAL_SD_STEPS=25
# LOCAL_SD_STRENGTH=0.80
# LOCAL_SD_GUIDANCE=12.0

# ── CV perception ────────────────────────────────
ENABLE_PERCEPTION=true
# Ceiling height anchor for Soviet/CIS apartments
CEILING_HEIGHT_M=2.5
